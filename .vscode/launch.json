{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "nuxt:production",
      "outputCapture": "std",
      "program": "${workspaceFolder}/node_modules/nuxt/bin/nuxt.mjs",
      "args": ["dev", "--port", "80", "--host", "0.0.0.0", "--dotenv", ".env.local", "--tunnel"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "nuxt:local",
      "outputCapture": "std",
      "program": "${workspaceFolder}/node_modules/nuxt/bin/nuxt.mjs",
      "args": ["dev", "--port", "80", "--host", "--dotenv", ".env.development.local"]
    }
  ]
}
