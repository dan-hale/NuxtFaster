# Neon / Postgres (required for catalog + auth)
DATABASE_URL=
POSTGRES_URL=

# JWT session signing (min 32 characters in production)
AUTH_SECRET=

# Upstash Redis (optional — auth rate limits are skipped if unset)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Origin for /api/prefetch-images server-side HTML fetch (match your dev server)
NUXT_PUBLIC_SITE_URL=http://localhost:3000
